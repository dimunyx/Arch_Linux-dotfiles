{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty",
    "source": "gentoo",
    "color": {
	    "1": "#89b4fa",
	    "2": "#89b4fa"
    }
  },
  "display": {
    "separator": " \u001b[38;2;180;190;254mÔÖ∏\u001b[0m ",
    "constants": [
      "\u001b[38;2;180;190;254m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\u001b[0m"
    ],
    "key": {
      "type": "icon",
      "paddingLeft": 2
    }
  },
  "modules": [
    {
      "type": "custom",
      "format": "\u001b[38;2;166;173;200m‚îå\u001b[0m{$1}\u001b[38;2;166;173;200mHardware\u001b[0m{$1}\u001b[38;2;166;173;200m‚îê\u001b[0m"
    },
    {
      "type": "host",
      "keyColor": "#89b4fa"
    },
    {
      "type": "cpu",
      "keyColor": "#89b4fa"
    },
    {
      "type": "disk",
      "keyColor": "#89b4fa"
    },
    {
      "type": "memory",
      "keyColor": "#89b4fa"
    },
    {
      "type": "battery",
      "keyColor": "#89b4fa"
    },
    {
      "type": "kernel",
      "keyColor": "#89b4fa"
    },
    {
      "type": "custom",
      "format": "\u001b[38;2;180;190;254m‚îî\u001b[0m{$1}\u001b[38;2;180;190;254m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\u001b[0m{$1}\u001b[38;2;180;190;254m‚îò\u001b[0m"
    },
    {
      "type": "custom",
      "format": "\u001b[38;2;166;173;200m‚îå\u001b[0m{$1}\u001b[38;2;166;173;200mSoftware\u001b[0m{$1}\u001b[38;2;166;173;200m‚îê\u001b[0m"
    },
    {
      "type": "os",
      "keyColor": "#89b4fa"
    },
    {
      "type": "de",
      "keyColor": "#89b4fa"
    },
    {
      "type": "wm",
      "keyColor": "#89b4fa"
    },
    {
      "type": "shell",
      "keyColor": "#89b4fa"
    },
    {
      "type": "terminal",
      "keyColor": "#89b4fa"
    },
    {
      "type": "icons",
      "keyColor": "#89b4fa"
    },
    {
      "type": "cursor",
      "keyColor": "#89b4fa"
    },
    {
      "type": "packages",
      "keyColor": "#89b4fa"
    },
    {
      "type": "uptime",
      "keyColor": "#89b4fa"
    },
    {
      "type": "command",
      "keyColor": "#89b4fa",
      "text": "birth_install=$(stat -c %W /); current=$(date +%s); time_progression=$((current - birth_install)); days_difference=$((time_progression / 86400)); echo $days_difference days"
    },
    {
      "type": "custom",
      "format": "\u001b[38;2;180;190;254m‚îî\u001b[0m{$1}\u001b[38;2;180;190;254m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\u001b[0m{$1}\u001b[38;2;180;190;254m‚îò\u001b[0m"
    }
  ]
}
